# Azure DevOps Personal Access Token with "Code (Read)" scope. Never commit the real .env file.
# If config/repos.yaml sets index_wikis or index_pull_requests, the same PAT is reused for
# those -- wikis clone like any other git repo (should work under "Code (Read)" alone, but
# check your org's PAT scoping if a project's wiki clone fails despite the wiki existing);
# pull requests are fetched via the REST API, which "Code (Read)" also covers.
AZURE_DEVOPS_PAT=your-pat-here

# LM Studio's local server (Developer tab -> Start Server). Docker Desktop on Windows can reach
# the host via host.docker.internal, so this works unchanged from inside the containers.
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=lm-studio
EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

# Postgres (pgvector + full-text) holds the whole index. The in-compose
# DATABASE_URL is set in docker-compose.yml; only set it here to point the
# services at a different database.
# DATABASE_URL=postgresql://sourcerag:sourcerag@postgres:5432/sourcerag

OUTPUT_CHUNK_SIZE=1500
OUTPUT_CHUNK_OVERLAP=200
EMBED_BATCH_SIZE=32

# --- API auth (optional: with neither credential type configured the API
# serves openly -- keep the loopback-only port binding in that case) ---

# Shared static key for agents/machine clients, sent as
# "Authorization: Bearer <key>". Generate one with: openssl rand -hex 32
# AGENT_API_KEY=replace-with-generated-key

# OAuth/OIDC for humans: the API validates JWTs from this issuer (it never
# runs login flows itself). Any OIDC-compliant IdP works. Entra ID example
# shapes below -- see README "Authentication" for the app-registration steps.
# OAUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# OAUTH_AUDIENCE=api://<client-id>
# OAUTH_SCOPES=api://<client-id>/mcp.read

# Externally visible base URL, used in 401 headers and the OAuth resource
# metadata. Only change when the API is exposed beyond localhost.
# PUBLIC_BASE_URL=http://localhost:4141

# Parallelism: CLONE_CONCURRENCY is network-bound, safe to set high.
# INDEX_CONCURRENCY is repos scanned+embedded in parallel (each repo does its
# own scan-then-embed in one worker, so embedding starts immediately per repo
# instead of waiting for every repo to be scanned first).
# EMBED_CONCURRENCY is concurrent calls to LM Studio -- bounded by what the
# local model server can actually parallelize, not by host CPU cores. Raise
# cautiously and watch for errors/slowdowns before increasing further.
CLONE_CONCURRENCY=8
INDEX_CONCURRENCY=4
EMBED_CONCURRENCY=2
